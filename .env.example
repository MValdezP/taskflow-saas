# Backend
DATABASE_URL="postgresql://taskflow:taskflow_secret@localhost:5432/taskflow_db"
JWT_SECRET="change-this-to-a-random-32-char-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# Frontend (.env.local)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Tras desplegar en Vercel, usa la URL pública del backend:
# NEXT_PUBLIC_API_URL="https://api.tu-dominio.com"

# URL pública del frontend (para README / enlaces; opcional)
# NEXT_PUBLIC_APP_URL="https://TU_PROYECTO.vercel.app"
